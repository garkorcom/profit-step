# Frontend environment variables (Vite).
# Copy to .env.local and fill in. All VITE_* vars are embedded in the
# production bundle at build time — only include config, never secrets.

# ─── Firebase Web SDK config ─────────────────────────────────────────
# Find these in Firebase Console → Project settings → General → Your apps
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── Agent API base URL ──────────────────────────────────────────────
# Cloud Functions URL for the agentApi (used by CRM frontend + SDK).
# Leave unset in production — the app falls back to a hardcoded default
# pointing at us-central1-profit-step.cloudfunctions.net/agentApi.
# Set explicitly when running against a different project or region.
VITE_FIREBASE_FUNCTIONS_URL=https://us-central1-YOUR_PROJECT.cloudfunctions.net/agentApi

# ─── Local Firebase emulators (dev-only) ─────────────────────────────
# When 'true', the web app connects to firebase emulators on 127.0.0.1.
# Requires `firebase emulators:start` running locally.
VITE_USE_EMULATORS=false

# ─── Optional integrations (leave blank to hide the feature) ─────────
# Infra Dashboard — separate AI-infra service (default port 8001).
# When blank, /admin/infra-map shows an empty-state instead of thrashing
# fetch on localhost.
VITE_INFRA_API_URL=

# Server Dashboard — external monitoring URL surfaced in the Admin menu.
# When blank, the menu item is hidden.
VITE_SERVER_DASHBOARD_URL=

# Blueprint AI — LangGraph Python service for estimates (default :8000).
# When blank, the Estimator LangGraph UI shows a "service not configured"
# message instead of failing at fetch time.
VITE_BLUEPRINT_AI_URL=

# CCTV landing dev preview — external landing URL shown on /crm/landings.
# Leave blank for production deployments that don't run the CCTV landing.
VITE_CCTV_LANDING_URL=
