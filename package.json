{
  "name": "profit-step",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "@mui/x-date-pickers": "^8.25.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/d3": "^7.4.3",
    "@types/jest": "^27.5.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "firebase": "^12.4.0",
    "gantt-task-react": "^0.3.9",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "pdfjs-dist": "^5.4.624",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.9.5",
    "recharts": "^3.5.1",
    "typescript": "^5.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.3.0",
    "@firebase/rules-unit-testing": "^3.0.4",
    "@types/sinon": "^17.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "cypress": "^13.6.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions-test": "^3.1.0",
    "firebase-tools": "^13.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-util": "^30.3.0",
    "oxlint": "^1.57.0",
    "sinon": "^17.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "vite": "^8.0.5"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build && node scripts/stamp-sw.js && node scripts/inject-firebase-config.js",
    "preview": "vite preview",
    "test": "jest",
    "test:unit": "jest --coverage",
    "test:security": "jest firestore.rules.test.ts --passWithNoTests",
    "test:integration": "jest --testMatch='**/*.integration.test.ts' --testPathIgnorePatterns='/node_modules/' --passWithNoTests",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:all": "npm run test:unit && npm run test:security && npm run test:integration && npm run test:e2e",
    "test:lighthouse": "node performance/lighthouse.test.js",
    "test:load": "artillery run artillery-load-test.yml --output reports/load-test.json",
    "seed:test": "ts-node scripts/seedTestData.ts",
    "seed:clean": "ts-node scripts/seedTestData.ts --clean",
    "emulator": "firebase emulators:start",
    "emulator:test": "firebase emulators:exec 'npm run test:all'",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "npx -y oxfmt@latest src/",
    "format:check": "npx -y oxfmt@latest --check src/"
  }
}
