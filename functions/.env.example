# ============================================================
# Profit Step — Firebase Functions Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# Firebase automatically loads .env from functions/ directory
# ============================================================

# === AI API Keys ===
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# === Telegram Bots ===
WORKER_BOT_TOKEN=your-worker-bot-token
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_TOKEN=your-super-estimator-bot-token
COSTS_BOT_TOKEN=your-costs-bot-token
WORKER_PASSWORD=your-worker-password

# === Email (Brevo SMTP) ===
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your-brevo-login@smtp-brevo.com
EMAIL_PASSWORD=your-brevo-smtp-key
EMAIL_FROM=your-from-email@example.com

# === WhatsApp ===
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token

# === OpenClaw Agent API ===
AGENT_API_KEY=your-agent-api-key
OWNER_UID=your-firebase-uid
OWNER_DISPLAY_NAME=Your Name
