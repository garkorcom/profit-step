rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================

    // Проверка аутентификации
    function isSignedIn() {
      return request.auth != null;
    }

    // Проверка владения ресурсом
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ==================== USER PROFILES ====================

    // Пользователи могут читать и обновлять ТОЛЬКО свой профиль
    // Создание и удаление выполняется ТОЛЬКО через Cloud Functions
    match /users/{userId} {
      // --- Вспомогательные функции для управления командой ---
      function getUserProfile(uid) {
        return get(/databases/$(database)/documents/users/$(uid)).data;
      }

      function requestingUserRole() {
        return getUserProfile(request.auth.uid).role;
      }

      function requestingUserCompanyId() {
        let data = getUserProfile(request.auth.uid);
        return 'companyId' in data ? data.companyId : null;
      }

      function isOwnProfile() {
        return request.auth.uid == userId;
      }

      function targetUserCompanyId() {
        return 'companyId' in resource.data ? resource.data.companyId : null;
      }

      function targetUserIsActive() {
        return resource.data.status == 'active';
      }

      // ЧТЕНИЕ:
      // Разрешено всем аутентифицированным пользователям
      // (нужно для dropdown выбора assignee в GTD и других местах)
      allow read: if isSignedIn();

      // СОЗДАНИЕ:
      // Разрешаем создание своего профиля (для AuthContext и seedLocalDb)
      allow create: if isSignedIn() && request.auth.uid == userId;

      // ОБНОВЛЕНИЕ:
      // Сложное правило с двумя сценариями:
      allow update: if
        // Сценарий 1: Я обновляю свой собственный профиль
        (isOwnProfile() &&
            // Разрешаем обновление lastSeen без ограничений
            (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeen']) ||
            // Backdoor for dev admin
            request.auth.token.email == 'admin@test.com' ||
            // Для остальных полей запрещаем менять критические данные
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'companyId'])))
        ||
        // Сценарий 2: Я Админ компании
        (requestingUserRole() == 'admin' &&
            requestingUserCompanyId() == targetUserCompanyId() &&
            // ...но не могу понизить роль самому себе
            !(isOwnProfile() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])));

      // УДАЛЕНИЕ:
      // Запрещено на клиенте. Только через Cloud Function 'adminDeleteUser'.
      allow delete: if false;
    }

    // ==================== USER DATA COLLECTIONS ====================

    // Проверка активности пользователя
    function userIsActive(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.status == 'active';
    }

    // Сметы пользователя (Estimates)
    match /users/{userId}/estimates/{estimateId} {
      allow read, write: if isOwner(userId) && userIsActive(request.auth.uid);
    }

    // Проекты пользователя (Projects)
    match /users/{userId}/projects/{projectId} {
      allow read, write: if isOwner(userId) && userIsActive(request.auth.uid);

      // Документы проекта
      match /documents/{documentId} {
        allow read, write: if isOwner(userId) && userIsActive(request.auth.uid);
      }
    }

    // Контрагенты пользователя (Counterparties)
    match /users/{userId}/counterparties/{counterpartyId} {
      allow read, write: if isOwner(userId) && userIsActive(request.auth.uid);
    }

    // Задачи пользователя (Tasks)
    match /users/{userId}/tasks/{taskId} {
      allow read, write: if isOwner(userId) && userIsActive(request.auth.uid);
    }

    // Товары/Инвентарь пользователя (Products)
    match /users/{userId}/products/{productId} {
      allow read, write: if isOwner(userId) && userIsActive(request.auth.uid);
    }

    // GTD Tasks (Lookahead)
    match /users/{userId}/gtd_tasks/{taskId} {
      allow read, write: if isOwner(userId) && userIsActive(request.auth.uid);
    }

    // Rate History (Finance/Payroll)
    match /users/{userId}/rate_history/{historyId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
    }

    // ==================== PUBLIC DATA ====================

    // Публичные сметы (для просмотра по ссылке)
    // Любой может читать, запись запрещена
    match /publicEstimates/{estimateId} {
      allow read: if true;
      allow write: if false;
    }

    // ==================== DASHBOARD COLLECTIONS ====================

    // Helper functions для дашбордов
    function isSuperAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    function getUserCompany() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // System-level collections (Super Admin only)
    match /systemErrors/{errorId} {
      allow read: if isSuperAdmin();
      allow write: if false; // Only via Cloud Functions
    }

    match /emailEvents/{eventId} {
      allow read: if isSuperAdmin();
      allow write: if false; // Only via Cloud Functions
    }

    match /costReports/{reportId} {
      allow read: if isSuperAdmin();
      allow write: if false; // Only via Cloud Functions
    }

    match /growthMetrics/{metricId} {
      allow read: if isSuperAdmin();
      allow write: if false; // Only via Cloud Functions
    }

    match /engagementMetrics/{metricId} {
      allow read: if isSuperAdmin();
      allow write: if false; // Only via Cloud Functions
    }

    // Company-scoped collections
    match /invitations/{inviteId} {
      // Чтение: только пользователи из той же компании
      allow read: if isSignedIn() &&
                     resource.data.companyId == getUserCompany();
      // Создание: только админы компании
      allow create: if isSignedIn() &&
                      request.resource.data.companyId == getUserCompany() &&
                      isAdmin();
      // Обновление/Удаление: только админы компании
      allow update, delete: if isSignedIn() &&
                              resource.data.companyId == getUserCompany() &&
                              isAdmin();
    }

    match /activityLog/{activityId} {
      // Чтение: только пользователи из той же компании
      allow read: if isSignedIn() &&
                     resource.data.companyId == getUserCompany();
      // Запись: только через Cloud Functions
      allow write: if false;
    }

    match /userActivation/{userId} {
      // Чтение: сам пользователь или superadmin
      allow read: if isSignedIn() &&
                     (request.auth.uid == userId || isSuperAdmin());
      // Запись: только через Cloud Functions
      allow write: if false;
    }

    match /featureUsage/{usageId} {
      // Чтение: все аутентифицированные пользователи
      allow read: if isSignedIn();
      // Создание: пользователи могут отслеживать свое использование
      allow create: if isSignedIn();
      // Обновление: только Cloud Functions
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      // Чтение: только для получателя уведомления
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Обновление: пользователь может отметить как прочитанное
      allow update: if isSignedIn() &&
                      resource.data.userId == request.auth.uid &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      // Создание/Удаление: только через Cloud Functions
      allow create, delete: if false;
    }

    // Companies collection (CRM - клиенты компании)
    match /companies/{companyId} {
      // Чтение: пользователи могут читать клиентов своей компании
      allow read: if isSignedIn() && resource.data.ownerCompanyId == getUserCompany();

      // Создание: только админы компании могут создавать клиентов
      allow create: if isSignedIn() &&
                      isAdmin() &&
                      request.resource.data.ownerCompanyId == getUserCompany();

      // Обновление: только админы компании могут обновлять своих клиентов
      allow update: if isSignedIn() &&
                      isAdmin() &&
                      resource.data.ownerCompanyId == getUserCompany();

      // Удаление: запрещено (используется архивация через update)
      allow delete: if false;

      // Tasks subcollection
      match /tasks/{taskId} {
        allow read, write: if isSignedIn();
      }
    }

    // Clients collection (CRM - клиенты/контрагенты)
    match /clients/{clientId} {
      // Чтение: пользователи могут читать клиентов своей компании
      // TEMPORARY FOR EMULATOR: Allow all authenticated users
      allow read: if isSignedIn();

      // Создание: только админы и менеджеры компании могут создавать клиентов
      // TEMPORARY FOR EMULATOR: Allow all authenticated users
      allow create: if isSignedIn();

      // Обновление: только админы и менеджеры компании могут обновлять своих клиентов
      // TEMPORARY FOR EMULATOR: Allow all authenticated users
      allow update: if isSignedIn();

      // Удаление: запрещено (используется архивация через update)
      allow delete: if false;
    }

    // Leads collection (Sales Funnel)
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }

    // Projects collection (Business Projects)
    match /projects/{projectId} {
      allow read, write: if isSignedIn();
    }

    // Landing Page Events (Analytics)
    match /landing_events/{eventId} {
      allow create: if true;
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    // GTD Tasks (Global collection for shared task management)
    // S-01: Hierarchical visibility - managers can see subordinates' tasks
    match /gtd_tasks/{taskId} {
      // Helper: check if requesting user is manager of task owner
      function isManagerOfOwner() {
        let ownerData = get(/databases/$(database)/documents/users/$(resource.data.ownerId)).data;
        // hierarchyPath contains [self, manager1, manager2, ..., topManager]
        // If requesting user's UID is in owner's hierarchyPath, they're a manager
        return 'hierarchyPath' in ownerData && 
               ownerData.hierarchyPath.hasAny([request.auth.uid]);
      }
      
      function isManagerOfAssignee() {
        let assigneeData = get(/databases/$(database)/documents/users/$(resource.data.assigneeId)).data;
        return 'hierarchyPath' in assigneeData && 
               assigneeData.hierarchyPath.hasAny([request.auth.uid]);
      }
      
      // Read: user is owner, assignee, manager in hierarchy, OR admin
      allow read: if isSignedIn() && 
                  (resource.data.ownerId == request.auth.uid || 
                   resource.data.assigneeId == request.auth.uid ||
                   isManagerOfOwner() ||
                   isManagerOfAssignee() ||
                   isAdmin());
      
      // Create: any authenticated user can create tasks
      allow create: if isSignedIn() && 
                    request.resource.data.ownerId == request.auth.uid;
      
      // Update: owner, assignee, or their manager can update
      allow update: if isSignedIn() && 
                    (resource.data.ownerId == request.auth.uid || 
                     resource.data.assigneeId == request.auth.uid ||
                     isManagerOfOwner() ||
                     isManagerOfAssignee());
      
      // Delete: only owner can delete
      allow delete: if isSignedIn() && 
                    resource.data.ownerId == request.auth.uid;
    }

    // Shopping Lists (Quick Shopping Flow)
    match /shopping_lists/{listId} {
      // Read: authenticated users can read lists they created or are assigned to
      allow read: if isSignedIn() && 
                  (resource.data.createdBy == request.auth.uid ||
                   resource.data.assignedTo == request.auth.uid ||
                   isAdmin());
      
      // Create: authenticated users can create shopping lists
      allow create: if isSignedIn();
      
      // Update: creator or assignee can update
      allow update: if isSignedIn() && 
                    (resource.data.createdBy == request.auth.uid ||
                     resource.data.assignedTo == request.auth.uid ||
                     isAdmin());
      
      // Delete: only creator or admin
      allow delete: if isSignedIn() && 
                    (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // Work Sessions (Time Tracking)
    match /work_sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn(); // Allow workers to create/update their sessions
      allow delete: if false; // Deletion only via admin or functions
    }

    // Notes (INBOX - captured from Telegram bot)
    match /notes/{noteId} {
      // Read: any authenticated user can read notes (for INBOX page)
      allow read: if isSignedIn();
      
      // Create: Cloud Functions only (from Telegram bot)
      allow create: if false;
      
      // Update: authenticated users can archive/update notes
      allow update: if isSignedIn();
      
      // Delete: only admin
      allow delete: if isAdmin();
    }

    // Pending Albums (temporary collection for album grouping)
    match /pending_albums/{albumId} {
      allow read, write: if false; // Cloud Functions only
    }

    // Employees Collection (for Rates & Mapping)
    match /employees/{employeeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      // Rate History
      match /rate_history/{historyId} {
        allow read: if isAdmin();
        allow write: if isAdmin();
      }
    }

    // Payroll Ledger (Finance)
    match /payroll_ledger/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin(); // Manual adjustments
      allow update: if false; // Ledger should be immutable mostly, or allow admin fixes?
      allow delete: if isAdmin();
    }

    // Costs Collection (Operational Expenses)
    match /costs/{costId} {
      // Read: any authenticated user can view costs
      allow read: if isSignedIn();
      
      // Create: Cloud Functions (from @gcostsbot) or authenticated users
      allow create: if isSignedIn();
      
      // Update: authenticated users can update costs (add prices, etc)
      allow update: if isSignedIn();
      
      // Delete: only admin
      allow delete: if isAdmin();
    }

    // Receipts Collection (Receipt photos with OCR)
    match /receipts/{receiptId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ==================== INVENTORY ====================

    // Inventory Catalog (materials, tools, equipment)
    match /inventory_catalog/{itemId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Inventory Transactions (journal — append-only)
    match /inventory_transactions/{txId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if false; // NEVER delete transactions
    }

    // Inventory Locations (warehouses, vehicles, jobsites)
    match /inventory_locations/{locId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Inventory Reservations
    match /inventory_reservations/{resId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Project Ledger (Project-level accounting)
    match /project_ledger/{entryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Bank Statements (Tax sorting module)
    match /bank_statements/{statementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Bank Transactions (Individual parsed transactions)
    match /bank_transactions/{txId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Bank Category Rules (AI learning)
    match /bank_category_rules/{ruleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Vendor Rules (User-defined category mappings)
    match /vendor_rules/{ruleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ==================== DEFAULT DENY ====================

    // Запретить доступ ко всем остальным документам
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

/**
 * ПРАВИЛА БЕЗОПАСНОСТИ FIRESTORE
 *
 * Эти правила обеспечивают:
 * 1. Пользователи могут работать ТОЛЬКО со своими данными
 * 2. Профили создаются/удаляются только через Cloud Functions
 * 3. Публичные сметы доступны для чтения всем
 * 4. Все остальное по умолчанию запрещено
 *
 * РАЗВЕРТЫВАНИЕ:
 * firebase deploy --only firestore:rules
 */
