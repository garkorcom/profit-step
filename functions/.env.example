# ============================================================
# Profit Step — Firebase Functions Environment Variables
# ============================================================
# Two kinds of values live here:
#
#   1. NON-SECRETS  (identifiers, hosts, ports, display strings, flags)
#      These are committed in this example file, copied to .env on dev
#      machines, and passed to Cloud Functions as plain env vars.
#
#   2. SECRETS      (API keys, tokens, passwords)
#      For LOCAL DEV + emulators: fill them in functions/.env (gitignored)
#      so the Firebase CLI can load them into your local functions.
#      For PRODUCTION: these live in Google Secret Manager. Bootstrap with
#           ./scripts/setup-secrets.sh
#      and bind per-function via { secrets: [...] } in the runtime options.
#      The SecretParam wrappers in functions/src/config/secrets.ts are the
#      single source of truth for which secrets exist.
#
# Onboarding a new machine? See docs/ONBOARDING.md §3.
# ============================================================

# ============================================================
# SECRETS — mirror these in Google Secret Manager for production
# ============================================================

# --- AI providers ---
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# --- Telegram bots ---
WORKER_BOT_TOKEN=your-worker-bot-token           # @gartime_bot (main worker bot)
COSTS_BOT_TOKEN=your-costs-bot-token             # costs/receipts bot
TELEGRAM_TOKEN=your-crm-api-bot-token            # @crmapiprofit_bot (AI assistant)
TELEGRAM_BOT_TOKEN=your-super-estimator-token    # blueprint pipeline output
WORKER_PASSWORD=your-4-digit-password            # worker bot login code

# --- Email (Brevo SMTP) ---
EMAIL_PASSWORD=your-brevo-smtp-key
BREVO_API_KEY=your-brevo-api-key                 # optional; only if you use transactional API

# --- Internal / external APIs ---
AGENT_API_KEY=your-agent-master-token            # gives /api/** admin scope

# ============================================================
# NON-SECRETS — passed to functions as env vars, not to GSM
# ============================================================

# --- Email SMTP ---
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your-brevo-login@smtp-brevo.com
EMAIL_FROM=your-from-email@example.com

# --- Owner / company identity ---
OWNER_UID=your-firebase-uid
OWNER_COMPANY_ID=your-company-id
OWNER_DISPLAY_NAME=Your Name

# --- Routing ---
ADMIN_GROUP_ID=                                  # optional Telegram chat id for admin notifications
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token
BLUEPRINT_AI_URL=http://localhost:8000           # LangGraph sidecar, optional
